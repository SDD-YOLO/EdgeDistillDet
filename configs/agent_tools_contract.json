{
  "version": "v3-agentic-rag",
  "runtime": "langgraph",
  "philosophy": "agentic rag with server-side react loop, retrieval/tool autonomy, explicit approval gate, replay-safe apply",
  "pipeline": [
    "agent.get_context",
    "agent.retrieve_context",
    "agent.analyze_params",
    "agent.propose_patch",
    "agent.validate_patch",
    "agent.preview_patch",
    "user_approval",
    "agent.apply_patch_with_approval"
  ],
  "tools": [
    {
      "name": "agent.get_context",
      "description": "读取 run 上下文与当前配置，并内联返回 training_results（来自 results.csv 的 latest/trend/epoch/tail_rows 摘要）",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "config_name": { "type": "string", "default": "distill_config.yaml" },
          "run_path": { "type": "string", "description": "可选，results.csv 路径或其父目录" },
          "tail": { "type": "integer", "default": 10, "description": "可选，返回最后 N 行指标原始数据" },
          "runs_root": { "type": "string", "default": "runs", "description": "可选，扫描根目录" }
        },
        "required": ["run_id"]
      }
    },
    {
      "name": "agent.retrieve_context",
      "description": "从项目语料和训练产物执行混合检索，返回可引用片段",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "run_id": { "type": "string", "default": "default" },
          "top_k": { "type": "integer", "default": 5 }
        },
        "required": ["query"]
      }
    },
    {
      "name": "agent.analyze_params",
      "description": "分析微调/蒸馏参数并给出可执行建议",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "objective": { "type": "string" },
          "config_name": { "type": "string", "default": "distill_config.yaml" }
        },
        "required": ["run_id", "objective"]
      }
    },
    {
      "name": "agent.propose_patch",
      "description": "输出候选 patch，不写入配置",
      "input_schema": {
        "type": "object",
        "properties": {
          "goal": { "type": "string" },
          "constraints": { "type": "object" }
        }
      }
    },
    {
      "name": "agent.validate_patch",
      "description": "校验 patch 的字段、类型与风险",
      "input_schema": {
        "type": "object",
        "properties": {
          "patch": { "type": "object" },
          "strict": { "type": "boolean", "default": true }
        },
        "required": ["patch"]
      }
    },
    {
      "name": "agent.preview_patch",
      "description": "生成审批票据和预览 diff",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "patch": { "type": "object" },
          "operator": { "type": "string", "default": "agent" },
          "reason": { "type": "string" }
        },
        "required": ["run_id", "patch"]
      }
    },
    {
      "name": "agent.apply_patch_with_approval",
      "description": "仅在用户批准后写入配置",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "approval_token": { "type": "string" },
          "request_hash": { "type": "string" },
          "operator": { "type": "string", "default": "agent" },
          "reason": { "type": "string" }
        },
        "required": ["run_id", "approval_token"]
      }
    },
    {
      "name": "agent.list_run_history",
      "description": "查询 run 最近 5 次变更",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" }
        },
        "required": ["run_id"]
      }
    },
    {
      "name": "agent.rollback_run_config",
      "description": "把配置回退到历史版本（窗口最多 5 条）",
      "input_schema": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "target_version": { "type": "integer" },
          "steps": { "type": "integer", "minimum": 1 },
          "operator": { "type": "string", "default": "agent" },
          "reason": { "type": "string" }
        },
        "required": ["run_id"]
      }
    }
  ],
  "constraints": {
    "allowed_patch_top_level": ["distillation", "training", "output"],
    "approval_required_for_apply": true,
    "rollback_window_per_run": 5,
    "max_react_steps_default": 4
  },
  "event_protocol": {
    "stream_route": "/api/agent/model/invoke-stream",
    "event_types": [
      "model_output",
      "retrieval_hit",
      "tool_start",
      "tool_end",
      "done",
      "error"
    ],
    "event_shape": {
      "event_type": "string",
      "timestamp": "number",
      "step": "number",
      "payload": "object"
    }
  },
  "error_codes": {
    "E_PATCH_INVALID": 400,
    "E_APPROVAL_EXPIRED": 400,
    "E_APPROVAL_REPLAY": 400,
    "E_RUN_HISTORY_EMPTY": 404,
    "E_INTERNAL": 500
  }
}
